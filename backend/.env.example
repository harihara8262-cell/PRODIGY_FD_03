# FastAPI Backend Configuration
PORT=8000
HOST=0.0.0.0

# Database Connection (Supabase PostgreSQL Connection String)
# Example: postgresql://postgres.xxxxxx:your-password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Supabase Auth Configuration
# Find this JWT Secret in Supabase Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
